{
  "name": "clean-tsql-formatter",
  "displayName": "Clean T-SQL Formatter",
  "description": "A VS Code formatter extension for T-SQL.",
  "version": "1.0.6",
  "license": "MIT",
  "publisher": "JMatos1221",
  "repository": {
    "type": "git",
    "url": "https://github.com/JMatos1221/tsql-formatter.git"
  },
  "homepage": "https://github.com/JMatos1221/tsql-formatter#readme",
  "bugs": {
    "url": "https://github.com/JMatos1221/tsql-formatter/issues"
  },
  "keywords": [
    "sql",
    "tsql",
    "formatter",
    "vscode",
    "extension"
  ],
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:sql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Clean T-SQL Formatter",
      "properties": {
        "tsqlFormatter.keywordCase": {
          "type": "string",
          "enum": [
            "upper",
            "lower",
            "preserve"
          ],
          "default": "preserve",
          "order": 10,
          "description": "Keyword casing mode."
        },
        "tsqlFormatter.identifierCase": {
          "type": "string",
          "enum": [
            "upper",
            "lower",
            "preserve"
          ],
          "default": "preserve",
          "order": 20,
          "description": "Identifier casing mode for database/schema/table/column names."
        },
        "tsqlFormatter.useBrackets": {
          "type": "boolean",
          "default": false,
          "order": 30,
          "description": "Wrap identifiers in square brackets when formatting (e.g., [TableName]). Variables (@var, @@sysvar) and temporary tables (#temp, ##global) are never bracketed."
        },
        "tsqlFormatter.breakOnKeywords": {
          "type": "boolean",
          "default": true,
          "order": 40,
          "description": "Break into a new line for keywords like WHERE, AND, OR, JOIN."
        },
        "tsqlFormatter.useMaxLineLength": {
          "type": "boolean",
          "default": true,
          "order": 50,
          "description": "When enabled, lines longer than maxLineLength are wrapped to a continuation line."
        },
        "tsqlFormatter.maxLineLength": {
          "type": "number",
          "default": 100,
          "minimum": 20,
          "order": 51,
          "description": "Maximum line length before formatter wraps onto a new continuation line."
        },
        "tsqlFormatter.linesBetweenQueries": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "order": 60,
          "description": "Number of empty lines between instructions (SELECT, DELETE, UPDATE, INSERT, etc.)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepare": "npm run compile"
  },
  "files": [
    "out",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/vscode": "^1.118.0",
    "typescript": "6.0.3"
  }
}
